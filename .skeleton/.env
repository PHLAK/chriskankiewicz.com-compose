# ------------------------------------------------------------------------------
# Version override. Update this value and restart your containers
# (i.e. 'docker compose up -d') to update your installation.
# ------------------------------------------------------------------------------

# IMAGE_VERSION=latest

# ------------------------------------------------------------------------------
# The application server port to be exposed to the host.
# ------------------------------------------------------------------------------

# APP_PORT=8080

# ------------------------------------------------------------------------------
# Host process user and group IDs. Setting these will map the host user/group
# to the user/group running within the container. This helps avoid permission
# issues between your host machine and docker container.
# ------------------------------------------------------------------------------

# HOST_USER_ID=
# HOST_GROUP_ID=
